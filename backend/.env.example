DB_HOST=localhost
DB_PORT=3306
DB_NAME=greenmarket
DB_USER=root
DB_PASSWORD=password
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json
GOOGLE_SHEETS_TIMEOUT_SECONDS=10
# Опционально: отдельная схема для Mode=TEST в рабочей книге продавца (см.
# app/publication/mode.py). Пусто — тестовый режим на этом окружении недоступен.
TEST_DB_NAME=
# S3-бакет для фотографий товаров (POST /api/v1/photos). Учётные данные AWS/R2
# берутся из стандартной цепочки boto3 (переменные окружения/~/.aws/credentials),
# не хранятся в .env.
S3_BUCKET=greenmarket-photos-dev
S3_REGION=us-east-1
# Опционально: для S3-совместимых хранилищ, отличных от AWS (например Cloudflare
# R2) — endpoint_url для boto3-клиента и публичный базовый URL для отдачи ссылок
# на фото (build_photo_url). Пусто — используется обычный AWS S3.
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
